meta {
  name: Get Stock Not Found
  type: http
  seq: 2
}

get {
  url: {{stockHost}}/stocks/:productId
  body: none
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

params:path {
  productId: 00000000-0000-0000-0000-000000000000
}

assert {
  res.status: eq 404
  res.body.success: eq false
  res.body.error: isDefined
}
