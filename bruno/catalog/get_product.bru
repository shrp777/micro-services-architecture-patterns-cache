meta {
  name: Get Product
  type: http
  seq: 3
}

get {
  url: {{host}}/catalog/products/:productId
  body: none
  auth: none
}

params:path {
  productId: {{productId}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.id: isDefined
  res.body.data.name: isDefined
  res.body.data.price: isDefined
  res.body.data.quantity: isDefined
}
