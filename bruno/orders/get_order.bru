meta {
  name: Get Order
  type: http
  seq: 3
}

get {
  url: {{host}}/orders/ref/:orderId
  body: none
  auth: none
}

params:path {
  orderId: {{orderId}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.data.id: isDefined
  res.body.data.status: isDefined
  res.body.data.total: isDefined
  res.body.data.items: isArray
}
