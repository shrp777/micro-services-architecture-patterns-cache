{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@config/*": ["src/config/*"],
      "@entities/*": ["src/entities/*"],
      "@routes/*": ["src/routes/*"],
      "@controllers/*": ["src/controllers/*"]
    }
  }
}
